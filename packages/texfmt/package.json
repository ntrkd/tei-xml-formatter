{
  "name": "texfmt",
  "version": "1.0.0",
  "description": "format tei xml files",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ntrkd/tei-xml-formatter.git"
  },
  "keywords": [
    "tei-xml",
    "formatter",
    "language",
    "typescript",
    "ts"
  ],
  "author": "ntrkd",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ntrkd/tei-xml-formatter/issues"
  },
  "homepage": "https://github.com/ntrkd/tei-xml-formatter#readme",
  "scripts": {
    "start": "tsc --watch",
    "build": "tsc && tsc-alias -p tsconfig.json",
    "postbuild": "esm2cjs --in ./dist/esm --out ./dist/cjs -l error",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "devDependencies": {
    "@alcalzone/esm2cjs": "^1.1.2",
    "tsc-alias": "^1.8.8",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "saxes": "^6.0.0"
  }
}
